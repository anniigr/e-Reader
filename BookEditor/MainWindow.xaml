<Window x:Class="BookEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookEditor"
        xmlns:viewmodels="clr-namespace:BookEditor.ViewModels"
        xmlns:views="clr-namespace:BookEditor.Views"
        xmlns:controls="clr-namespace:BookEditor.Controls"
        mc:Ignorable="d"
        Title="Libraria" 
        Height="650" Width="1000" 
        MinHeight="500" MinWidth="920"
        Icon="pack://application:,,,/book.ico">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:WelcomeViewModel}">
            <views:WelcomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:BookListViewModel}">
            <views:BookListView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Repository">
                <MenuItem Header="Create" Command="{Binding CreateRepoCommand}"/>
                <MenuItem Header="Open" Command="{Binding OpenRepoCommand}"/>
            </MenuItem>
            <MenuItem Header="Book">
                <MenuItem Header="Add..." Command="{Binding CurrentPage.AddBookCommand}"/>
                <MenuItem Header="Edit..." Command="{Binding CurrentPage.EditBookCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Delete..." Command="{Binding CurrentPage.DeleteBookCommand}" InputGestureText="Del"/>
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Top" Height="64" Background="{DynamicResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <Image Source="pack://application:,,,/book.png" Height="40" Width="40" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="Libraria" FontFamily="Segoe Script" FontSize="28" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="Personal Book Manager" Foreground="LightGray" FontSize="14" VerticalAlignment="Bottom" Margin="10,0,0,12"/>
            </StackPanel>
        </Grid>

        <controls:StatisticsBarControl DockPanel.Dock="Bottom" DataContext="{Binding Statistics}" />

        <ContentControl Content="{Binding CurrentPage}" />
    </DockPanel>
</Window>