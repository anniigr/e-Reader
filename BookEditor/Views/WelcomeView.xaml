<UserControl x:Class="BookEditor.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Grid Background="White">
		<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

			<TextBlock Text="Welcome to BookEditor" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
			<TextBlock Text="Create a new library or open an existing one to get started" FontSize="15" HorizontalAlignment="Center" Margin="0,0,0,30"/>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

				<Button Content="Open Repository"
                        Command="{Binding OpenRepoCommand}"
                        Background="#E67E22"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Padding="20,12"
                        Margin="10"
                        BorderThickness="0"
                        Cursor="Hand"/>

				<Button Content="Create Repository"
                        Command="{Binding CreateRepoCommand}"
                        Background="#2980B9"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Padding="20,12"
                        Margin="10"
                        BorderThickness="0"
                        Cursor="Hand"/>

			</StackPanel>

		</StackPanel>
	</Grid>
</UserControl>