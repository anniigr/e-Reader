<UserControl x:Class="BookEditor.Views.BookDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BookEditor.Converters"
             xmlns:controls="clr-namespace:BookEditor.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ByteArrayToImageConverter x:Key="ImageConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Button Content="← Wstecz" Command="{Binding GoBackCommand}" Margin="0,0,0,15" Padding="5" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Foreground="DimGray" Cursor="Hand" FontWeight="Bold"/>

                <Border Width="180" Height="240" BorderBrush="#CCC" BorderThickness="1" Background="#EEE" Margin="0,0,0,15">
                    <Grid>
                        <TextBlock Text="No Cover" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                        <Image Source="{Binding Book.CoverImage, Converter={StaticResource ImageConverter}}" Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <controls:RatingControl Value="{Binding Book.Rating}" IsReadOnly="True" StarSize="24" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Button Content="Czytaj od początku" 
                        Command="{Binding ReadFromBeginningCommand}" 
                        Visibility="{Binding CanRead, Converter={StaticResource BoolToVis}}" 
                        Background="{DynamicResource PrimaryBrush}" Foreground="White" Padding="10" Margin="0,0,0,10"/>

                <Button Content="Kontynuuj czytanie" 
                        Command="{Binding ContinueReadingCommand}" 
                        Visibility="{Binding CanContinueReading, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource AccentBrush}" Foreground="White" Padding="10" Margin="0,0,0,10"/>

                <Button Content="Edytuj" Command="{Binding EditCommand}" Padding="10" Margin="0,0,0,10"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Book.Title}" FontSize="32" FontWeight="Bold" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Book.Author}" FontSize="20" Foreground="Gray" Margin="0,5,0,20" TextWrapping="Wrap"/>

                <StackPanel Visibility="{Binding HasProgress, Converter={StaticResource BoolToVis}}" Margin="0,0,0,20">
                    <TextBlock Text="Postęp czytania:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock>
                        <Run Text="{Binding Book.CurrentPage}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding Book.TotalPages}"/>
                        <Run Text=" str."/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Visibility="{Binding HasTags, Converter={StaticResource BoolToVis}}" Margin="0,0,0,20">
                    <TextBlock Text="Tagi:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <controls:TagControl Tags="{Binding Book.Tags}" IsReadOnly="True" ChipBackground="{DynamicResource PrimaryBrush}"/>
                </StackPanel>

                <StackPanel Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" Margin="0,0,0,20">
                    <TextBlock Text="Opis:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Book.Description}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>