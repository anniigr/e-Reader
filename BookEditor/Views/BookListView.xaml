<UserControl x:Class="BookEditor.Views.BookListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BookEditor.Converters"
             xmlns:controls="clr-namespace:BookEditor.Controls">

    <UserControl.Resources>
        <converters:ByteArrayToImageConverter x:Key="ImageConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteBookCommand}" />
    </UserControl.InputBindings>

    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
			
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="5,0"/>
                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding FilterStatus}" Width="110" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <TextBlock Text="Min Rating:" VerticalAlignment="Center" Margin="5,0"/>
                <ComboBox ItemsSource="{Binding RatingOptions}" SelectedItem="{Binding FilterRating}" Width="50" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <TextBlock Text="Sort by:" VerticalAlignment="Center" Margin="5,0"/>
                <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SortBy}" Width="100" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Padding="10,2" Margin="10,0"/>
            </WrapPanel>
        </Border>

        <ListBox Grid.Row="1" ItemsSource="{Binding FilteredBooks}" SelectedItem="{Binding SelectedBook}" 
                 Background="Transparent" BorderThickness="0" Padding="15"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" BorderBrush="Transparent" BorderThickness="2" Background="White" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="1"/>
                                    </Border.Effect>
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="LightGray"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="Bd" Property="Background" Value="#FFF0F5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="130">
                        <Border Width="120" Height="160" BorderBrush="#EEE" BorderThickness="1" Background="#E0E0E0" Margin="0,0,0,5">
                            <Grid>
                                <TextBlock Text="No Cover" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="DimGray"/>
                                <Image Source="{Binding CoverImage, Converter={StaticResource ImageConverter}}" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}"/>
                        <TextBlock Text="{Binding Author}" Foreground="Gray" TextTrimming="CharacterEllipsis" ToolTip="{Binding Author}"/>
                        <controls:RatingControl Value="{Binding Rating}" IsReadOnly="True" StarSize="14" Margin="0,2,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>